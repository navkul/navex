{
  "name": "navex",
  "version": "0.1.0",
  "description": "Personal macOS session manager for interactive Codex work.",
  "type": "module",
  "bin": {
    "navex": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    ".codex/hooks.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js && node scripts/build-overlay.mjs",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "codex",
    "macos",
    "overlay",
    "terminal",
    "hooks"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
