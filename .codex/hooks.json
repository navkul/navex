{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "navex hook session-start",
            "statusMessage": "Navex registering session"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "navex hook user-prompt-submit",
            "statusMessage": "Navex clearing delivered notifications"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "navex hook stop",
            "timeout": 5,
            "statusMessage": "Navex queueing session notification"
          }
        ]
      }
    ]
  }
}
